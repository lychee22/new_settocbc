# Nginx 配置示例 - new_settocbc React 前端

server {
    listen 3000;
    server_name localhost;

    # React 静态文件
    location / {
        root /path/to/new_settocbc/dist;
        index index.html;
        try_files $uri $uri/ /index.html;
    }

    # 代理到旧 JSP 后端
    location /BOAppLoginServlet {
        proxy_pass http://localhost:8080/BOAppLoginServlet;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    }

    location /BOAppPullServlet {
        proxy_pass http://localhost:8080/BOAppPullServlet;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    }

    location /FOAdminPushServlet {
        proxy_pass http://localhost:8080/FOAdminPushServlet;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    }

    # 代理其他 BO 请求到旧后端
    location /boadmin {
        proxy_pass http://localhost:8080/boadmin;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
    }

    location /botrans {
        proxy_pass http://localhost:8080/botrans;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
    }

    location /bologin {
        proxy_pass http://localhost:8080/bologin;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
    }
}
